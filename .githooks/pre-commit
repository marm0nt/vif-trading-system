#!/bin/bash
# Pre-commit hook: Prevent venv hardcoding from reaching git
# Install: git config core.hooksPath .githooks

VENV_PATTERNS=(
    'venv/Scripts'
    'venv/bin'
    '.venv/Scripts'
    '.venv/bin'
    'VENV_PYTHON'
    'subprocess.*venv'
)

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

errors=0

# Check staged Python files for venv hardcoding
for file in $(git diff --cached --name-only --diff-filter=ACM | grep -E '\.py$'); do
    if [ -f "$file" ]; then
        for pattern in "${VENV_PATTERNS[@]}"; do
            if grep -q "$pattern" "$file"; then
                echo -e "${RED}✗ $file contains hardcoded venv path: $pattern${NC}"
                ((errors++))
            fi
        done
    fi
done

if [ $errors -gt 0 ]; then
    echo
    echo -e "${RED}Pre-commit check FAILED${NC}"
    echo "Found $errors file(s) with hardcoded venv references."
    echo
    echo "FIX: Replace hardcoded venv paths with system Python:"
    echo "  BEFORE: PYTHON = str(Path('venv') / 'Scripts' / 'python.exe')"
    echo "  AFTER:  PYTHON = 'python'  # Use sys.executable or 'python' directly"
    echo
    echo "Rationale: Dependencies installed via pyproject.toml + pip globally."
    echo "No venv activation needed. Prevents path failures across machines."
    echo
    exit 1
fi

echo -e "${GREEN}✓ Pre-commit: No venv hardcoding detected${NC}"
exit 0
